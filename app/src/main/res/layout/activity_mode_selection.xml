<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Family Protect"
        android:textColor="#3182CE"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="SELECT DEVICE MODE"
        android:textColor="#4A5568"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="48dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_parent_mode"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="20dp"
        android:text="👨‍👩‍👧 PARENT MODE\nControl &amp; Monitor"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:elevation="2dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_child_mode"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="32dp"
        android:text="👶 CHILD MODE\nBeing Monitored"
        android:textAllCaps="false"
        android:textColor="#4A5568"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:strokeColor="#CBD5E0"
        app:strokeWidth="2dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FED7D7"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="12dp"
            android:text="⚠️ This selection cannot be changed without PIN"
            android:textColor="#C53030"
            android:textSize="12sp"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
